# ── 필수 ──────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_BotFather

# 허용할 Telegram user_id (쉼표 구분). 비워두면 모든 사용자 허용 (비권장)
ALLOWED_USER_IDS=123456789,987654321

# ── LLM API 키 (사용하는 프로바이더만 입력) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# LMStudio / Ollama 는 키 불필요 — config.yaml 의 base_url 만 조정
